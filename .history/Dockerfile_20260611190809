# 改回官方基础镜像，配合代理参数拉取
FROM python:3.14-slim

# 设置工作目录
WORKDIR /app

# 复制依赖文件，同时给pip加上代理
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt -i https://pypi.org/simple

# 复制所有项目文件（包含static前端文件夹）
COPY . .

# 暴露端口
EXPOSE 8000

# 启动命令
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]