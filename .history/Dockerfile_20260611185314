# 用阿里云镜像源的Python基础镜像，避开docker.io和代理
FROM registry.aliyuncs.com/library/python:3.14-slim

# 设置工作目录
WORKDIR /app

# 复制依赖文件，用阿里云pip源安装，避免代理影响
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt -i https://mirrors.aliyun.com/pypi/simple/

# 复制所有项目文件（包含static前端文件夹）
COPY . .

# 暴露端口
EXPOSE 8000

# 启动命令
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]