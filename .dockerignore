# ── 敏感文件（不要打入镜像）──────────────────────────
.env
.env.local
.env.*.local

# ── Python ───────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
*.egg

# ── 开发工具 ─────────────────────────────────────────
.git/
.gitignore
.history/
.vscode/
.idea/
*.swp
*.swo

# ── 前端（不需要构建，static/ 已有构建产物）──────────
his-frontend/
node_modules/

# ── 测试 & 文档 ──────────────────────────────────────
tests/
*.md
README.md
LICENSE

